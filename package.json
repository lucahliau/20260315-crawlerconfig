{
  "name": "crawler-config-generator",
  "version": "1.0.0",
  "description": "Stagehand-based tool that explores retailer websites and generates JSON config files for automated crawling",
  "type": "module",
  "scripts": {
    "start": "tsx --env-file=.env src/explore.ts",
    "explore": "tsx --env-file=.env src/explore.ts",
    "ui": "tsx --env-file=.env src/server.ts"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.1.0",
    "express": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
