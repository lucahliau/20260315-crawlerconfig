# Required: Gemini API (Google AI Studio) — used by Stagehand and niche brand discovery.
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-studio-api-key

# Stagehand browser automation model (v3 format). Default: google/gemini-3-flash-preview
# STAGEHAND_MODEL=google/gemini-3-flash-preview

# Discover brands: Gemini model id (not the Stagehand "google/..." string). Default: gemini-3-flash-preview
# GEMINI_DISCOVER_MODEL=gemini-3-flash-preview

# HTTP timeout for discover (ms). Default 1800000 (30 min). Same as GEMINI_TIMEOUT_MS.
# DISCOVER_TIMEOUT_MS=1800000

# LOCAL = Chrome on this machine; BROWSERBASE = cloud browser (needs BROWSERBASE_API_KEY + BROWSERBASE_PROJECT_ID).
STAGEHAND_ENV=LOCAL

# When STAGEHAND_ENV=BROWSERBASE, the app defaults to disableAPI=true so Gemini runs with your key only
# (avoids HTTP 402 from the hosted Stagehand API). Set to true only if you intentionally use that API.
# STAGEHAND_USE_API=false

# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# Optional: USD per million input/output tokens for cost estimates (defaults approximate Gemini Flash list pricing).
# GEMINI_INPUT_USD_PER_MTOK=0.3
# GEMINI_OUTPUT_USD_PER_MTOK=2.5
# GEMINI_GROUNDING_USD_PER_REQUEST=0.01

# Docker / restricted networks: allow outbound HTTPS to Google AI endpoints. If required, set Node-compatible proxy env, e.g.:
# HTTPS_PROXY=http://proxy:8080
# HTTP_PROXY=http://proxy:8080
# NO_PROXY=localhost,127.0.0.1

# Where this app stores usage events for the cost strip (default: ./usage-ledger.json)
# USAGE_LEDGER_PATH=
# USAGE_LEDGER_MAX_EVENTS=2000

# Railway / hosted deployment notes:
# - Critical pipeline state now persists in Postgres via DATABASE_URL.
# - Local directories below are still written for visibility/debugging, but should be treated as cache/artifacts
#   on ephemeral hosts unless you attach persistent storage.
# CONFIGS_DIR=./configs
# PRODUCT_URLS_DIR=./product-urls
# UPLOAD_STATUS_DIR=./upload-status
# EXPLORATION_ARTIFACTS_DIR=./exploration-artifacts
# JOB_LOGS_DIR=./logs
# DISCOVERED_BRANDS_PATH=./discovered-brands.json

# Crawl checkpoint defaults are now enabled in code for safer long runs on Railway.
# Set either value to 0 only if you intentionally want to disable that checkpoint trigger.
# CRAWL_CHECKPOINT_EVERY_N=250
# CRAWL_CHECKPOINT_EVERY_MS=30000

# Optional upload browser recycle controls for long product runs.
# UPLOAD_BROWSER_REFRESH_EVERY_N=100
# UPLOAD_BROWSER_REFRESH_AFTER_CONSECUTIVE_FAILURES=4
# UPLOAD_NAV_TIMEOUT_MS=20000
