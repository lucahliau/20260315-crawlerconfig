ANTHROPIC_API_KEY=
STAGEHAND_ENV=LOCAL

# Optional: USD per million input/output tokens for cost estimates (defaults match Sonnet-class list pricing).
# CLAUDE_SONNET_INPUT_USD_PER_MTOK=3
# CLAUDE_SONNET_OUTPUT_USD_PER_MTOK=15
# CLAUDE_WEB_SEARCH_USD_PER_REQUEST=0.01
# CLAUDE_CACHE_WRITE_USD_PER_MTOK=
# CLAUDE_CACHE_READ_USD_PER_MTOK=0.3

# Where this app stores usage events for the cost strip (default: ./usage-ledger.json)
# USAGE_LEDGER_PATH=
# USAGE_LEDGER_MAX_EVENTS=2000
